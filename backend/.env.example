# Copy to .env and fill in values

# Database
# SQLite (dev): sqlite:///./ticketrush.db
# PostgreSQL (prod): postgresql://user:password@localhost:5432/ticketrush
DATABASE_URL=sqlite:///./ticketrush.db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Seat lock timeout (minutes)
SEAT_LOCK_MINUTES=10

# Virtual queue - max concurrent users on seat selection page per event
QUEUE_BATCH_SIZE=50
QUEUE_ADMIT_INTERVAL_SECONDS=30

# Email / SMTP — dùng để gửi link đặt lại mật khẩu
# Gmail: tạo App Password tại https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=TicketRush <your@gmail.com>

# URL frontend — dùng để tạo link reset trong email
FRONTEND_URL=http://localhost:5173
