# Copy to .env and fill in values

# Database (PostgreSQL)
# Tạo database trước: CREATE DATABASE ticketrush;
DATABASE_URL=postgresql://postgres:password@localhost:5432/ticketrush

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Seat lock timeout (minutes)
SEAT_LOCK_MINUTES=10

# Virtual queue - max concurrent users on seat selection page per event
QUEUE_BATCH_SIZE=50
QUEUE_ADMIT_INTERVAL_SECONDS=30

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Used to send password-reset emails to users.
#
# SETUP (Gmail - recommended):
#   1. Enable 2-Step Verification on your Google account:
#      https://myaccount.google.com/security
#   2. Generate a 16-character App Password:
#      https://myaccount.google.com/apppasswords
#      → Click "Create", name it "TicketRush", copy the password shown.
#   3. Fill in the values below with your Gmail address and that App Password.
#
# NOTE: Never commit the real .env file - it's listed in .gitignore.
#       Only commit this .env.example file (with placeholder values).
#
# DEV MODE (no email needed):
#   Set APP_ENV=development and leave SMTP_USER/SMTP_PASSWORD empty.
#   The backend will log the reset link to the console instead of sending email,
#   and the forgot-password page will display the link directly in the browser.
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=TicketRush <your@gmail.com>

# Base URL of the frontend - used to build the reset-password link in the email.
# Change to your production domain when deploying.
FRONTEND_URL=http://localhost:5173

GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash